<script type="text/javascript">
if (typeof i$ == "undefined") {
  var hook = document.getElementById("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_asyncRenderingHook");
  if (hook!=null && hook.parentNode!=null) {
    hook.parentNode.innerHTML = "El tema asignado a la página no incluye los módulos de tema de Utilidad de cliente. Añada los módulos de tema de Utilidad de cliente al tema asignado o configure el portlet Visor de contenido web para representar el contenido web de forma síncrona en lugar de hacerlo de forma asíncrona.";
  }
}

if (typeof wp_wcm_async != "undefined") {
  wp_wcm_async.registerAsyncSpot("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_");
}

function errorCase(hook) {
  if (hook != null) {
    i$.xhrGet({"url": hook.href, "sync": false})
      .then(i$.scope(this, function(handle) { // success
        if (handle.xhr.status==200) {
          if (hook.parentNode != null) {
            hook.parentNode.innerHTML = handle.xhr.responseText;
          }
        }
      }), i$.scope(this, function(handle) { // failure
        console.error("Unable to retrieve error markup from " + hook.href);
      }));
  }
}

(function() {
  if (typeof i$ != "undefined") {
    try {
      var hook = document.getElementById("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_asyncRenderingHook");
      i$.xhrGet({ "url": hook.href,
                  "sync": false, 
                  "timeout": 5000 })
        .then(i$.scope(this, function(handle) { // success
          if (handle.xhr.status==200) {
            if (hook != null && hook.parentNode != null) {
              hook.parentNode.innerHTML = handle.xhr.responseText;
            }
          }
          if (typeof wp_wcm_async != "undefined") {
            wp_wcm_async.asyncSpotLoaded("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_");
          }
        }), i$.scope(this, function(handle) { // failure
          if (handle.data == "timeout") {
            errorCase(document.getElementById("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_asyncRenderingHookTimeoutOccurred"));
          } else {
            errorCase(document.getElementById("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_asyncRenderingHookServerError"));
          }
          
        if (typeof wp_wcm_async != "undefined") {
            wp_wcm_async.asyncSpotLoaded("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_");
          }
        }));

    } catch (err) {
      console.error(err);

      var hook = document.getElementById("ns_Z7_OAH81840O8DJ506RN6BN0K0MQ5_asyncRenderingHook");
      if (hook != null && hook.parentNode != null) {
        hook.parentNode.innerHTML = "El contenido web no se puede visualizar en este momento, ya que la solicitud de representación de contenido web ha fallado en el navegador web. Intente volver a cargar la página. Si el problema persiste, póngase en contacto con el administrador.";
      }
    }
  }
}());
</script>


















