<div class="row">
  <div class="col-sm-12 bannersH" id="ecp-video-module" data-video1="https://youtu.be/4JOQkOzOenA?si=M0hLfbFg4Zt9nxnQ" data-video2="https://youtu.be/2FFBzTQ5Xfw?si=qvrRF9kgFCqn5vMY" data-title1="Energía Viva - Capítulo 16" data-title2="Energía Viva - Capítulo 15" data-desc1="Energía Viva - Capítulo 16" data-desc2="Energía Viva - Capítulo 15">

