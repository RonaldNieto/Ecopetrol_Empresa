<script>
(function () {
  var AUTOPLAY = true;
  var ROTATE_NEXT = true;

  function ytId(url) {
    if (!url) return null;
    var m = url.match(/(?:youtu\.be\/|watch\?v=|\/embed\/)([^#&?]+)/);
    return m ? m[1].slice(0, 11) : null;
  }

 function setImgSafe(imgEl, maxUrl, hqUrl) {
  if (!imgEl) return;

  // mostrar placeholder mientras carga (no ocultar completamente)
  imgEl.style.display = 'block';
  imgEl.style.visibility = 'hidden'; // evita el icono roto, pero mantiene el espacio
  imgEl.loading = 'lazy';
  imgEl.decoding = 'async';

  var triedHq = false;

  function showIfOk() {
    if (imgEl.complete && imgEl.naturalWidth > 0) {
      imgEl.style.visibility = 'visible';
      return true;
    }
    return false;
  }

  imgEl.onload = function () {
    imgEl.style.visibility = 'visible';
  };

  imgEl.onerror = function () {
    if (!triedHq) {
      triedHq = true;
      imgEl.src = hqUrl;
      return;
    }
    // si también falla hq, deja un placeholder neutro
    imgEl.style.visibility = 'hidden';
  };

  // 1) intenta maxres
  imgEl.src = maxUrl;

  // 2) si ya estaba en cache y cargó instantáneo, muéstrala
  showIfOk();
}

  function boot() {
    var root = document.getElementById('ecp-video-module');
    if (!root) return;

    var container = document.getElementById('ecp-player-container');
    var iframe = document.getElementById('ecp-iframe');
    var mainThumb = document.getElementById('ecp-main-thumb');
    var mainPlay = document.getElementById('ecp-main-play');

    var titleEl = document.getElementById('ecp-main-title');
    var descEl  = document.getElementById('ecp-main-desc');

    var nextBtn   = document.getElementById('ecp-next-btn');
    var nextThumb = document.getElementById('ecp-next-thumb');
    var nextTitle = document.getElementById('ecp-next-title');
    var nextDur   = document.getElementById('ecp-next-duration');

    if (!container || !iframe || !mainThumb || !mainPlay || !nextBtn) return;

    // Tomar URLs del HTML (WCM)
    var url1 = (root.dataset.video1 || '').trim();
    var url2 = (root.dataset.video2 || '').trim();

    var id1 = ytId(url1);
    var id2 = ytId(url2);

    if (!id1) {
      if (titleEl) titleEl.textContent = 'No hay video principal.';
      return;
    }

    var videos = [
      {
        id: id1,
        title: (root.dataset.title1 || 'Video Ecopetrol').trim(),
        desc:  (root.dataset.desc1  || '').trim(),
        thumbMax: 'https://img.youtube.com/vi/' + id1 + '/maxresdefault.jpg',
        thumbHQ:  'https://img.youtube.com/vi/' + id1 + '/hqdefault.jpg'
      }
    ];

    if (id2) {
      videos.push({
        id: id2,
        title: (root.dataset.title2 || 'Video Ecopetrol').trim(),
        desc:  (root.dataset.desc2  || '').trim(),
        thumbMax: 'https://img.youtube.com/vi/' + id2 + '/maxresdefault.jpg',
        thumbHQ:  'https://img.youtube.com/vi/' + id2 + '/hqdefault.jpg'
      });
    }

    var cur = 0;
    var nxt = videos.length > 1 ? 1 : 0;

    function setMainTexts(v) {
      if (titleEl) titleEl.textContent = v.title || 'Video Ecopetrol';
      if (descEl)  descEl.textContent  = v.desc || '';
    }

    function showThumbMode(v) {
      // Mostrar thumbnail + play, ocultar iframe
      iframe.style.display = 'none';
      iframe.setAttribute('src', 'about:blank');
      mainPlay.style.display = 'flex';
      setImgSafe(mainThumb, v.thumbMax, v.thumbHQ);
      setMainTexts(v);
    }

    function playVideo(v, autoplay) {
      // Ocultar thumbnail + play, mostrar iframe
      mainThumb.style.display = 'none';
      mainPlay.style.display = 'none';
      iframe.style.display = 'block';

      var src = 'https://www.youtube-nocookie.com/embed/' + v.id + '?rel=0';
      if (autoplay) src += '&autoplay=1';
      iframe.src = src;

      setMainTexts(v);
    }

    function renderNextCard(v) {
      if (!v) {
        nextBtn.style.display = 'none';
        return;
      }
      nextBtn.style.display = '';
      if (nextTitle) nextTitle.textContent = v.title || 'Video Ecopetrol';
      if (nextDur) nextDur.style.display = 'none';
      setImgSafe(nextThumb, v.thumbMax, v.thumbHQ);
    }

    // Eventos (bind una sola vez)
    if (!mainPlay.dataset.bound) {
      mainPlay.addEventListener('click', function () {
        playVideo(videos[cur], true);
      });
      mainPlay.dataset.bound = '1';
    }

    if (!nextBtn.dataset.bound) {
      nextBtn.addEventListener('click', function () {
        if (videos.length < 2) return;

        if (ROTATE_NEXT) {
          var t = cur; cur = nxt; nxt = t;
        } else {
          cur = nxt;
          nxt = (nxt + 1) % videos.length;
        }

        if (AUTOPLAY) playVideo(videos[cur], true);
        else showThumbMode(videos[cur]);

        renderNextCard(videos[nxt]);
      });
      nextBtn.dataset.bound = '1';
    }

    // Render inicial: thumbnail (no iframe) + siguiente
    showThumbMode(videos[cur]);
    renderNextCard(videos[nxt]);
  }

  // Lazy init cuando el módulo entre al viewport
  function start() {
    var el = document.getElementById('ecp-player-container');
    if (!el) return;

    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            boot();
            io.disconnect();
            break;
          }
        }
      }, { rootMargin: '300px 0px' });
      io.observe(el);
    } else {
      boot();
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', start);
  } else {
    start();
  }
})();
</script>

