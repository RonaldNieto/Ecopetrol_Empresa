<script>
function redesCompartirPost2(Ncont, reds){
  var urlCompartir2 = "https://www.ecopetrol.com.co/wps/portal/Home/es/noticias/detalle/";

  if(reds == 'Facebook'){

    window.open("https://www.facebook.com/sharer/sharer.php?u="+urlCompartir2+Ncont, '_blank', "width=600,height=400");
  }

  if(reds == 'Twitter'){

    window.open("http://twitter.com/share?text=Noticia&url="+urlCompartir2+Ncont, '_blank', "width=600,height=400");
  }

  if(reds == 'Linkedin'){
    window.open("https://www.linkedin.com/shareArticle?mini=true&title=Noticia&url="+urlCompartir2+Ncont, '_blank', "width=600,height=400");
  }

}
</script>


        
        
    

    
        





        







    
