<script>
document.addEventListener('DOMContentLoaded', function () {
  const box = document.querySelector('#searcher_inner');
  if (!box) return;

  // Intenta localizar el campo de búsqueda dentro del contenedor
  const input = box.querySelector('input[type="search"], input[type="text"]');
  if (!input) return;

  // Asigna ID si no tiene
  if (!input.id) input.id = 'site-search';

  // Crea un label oculto
  const label = document.createElement('label');
  label.setAttribute('for', input.id);
  label.className = 'a11y-only';
  label.textContent = 'Buscar en el sitio';

  // Inserta el label antes del input
  input.parentNode.insertBefore(label, input);
});
document.querySelector('.closed_search')?.addEventListener('keydown', e=>{
  if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); e.currentTarget.click(); }
});

document.querySelectorAll('.box_search input').forEach(i => {
  if (!i.getAttribute('aria-label') && !i.getAttribute('aria-labelledby')) {
    i.setAttribute('aria-label','Buscar en el sitio');
  }
});
const a = document.getElementById('config_js_deferred');
if (a && a.hasAttribute('href')) {
  const sinTexto = a.textContent.trim() === '' && !a.querySelector('img[alt]');
  const sinNombre = !a.getAttribute('aria-label') && !a.getAttribute('aria-labelledby');
  if (sinTexto && sinNombre) {
    a.setAttribute('aria-label', 'Abrir configuración'); // texto significativo
  }
}
</script>
