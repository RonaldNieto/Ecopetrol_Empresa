      <h3>Energía Viva</h3>
    </div>

    <!-- Izquierda -->
    <div class="col-md-8 bannersH">
      <div class="card">
        <div class="card_img ecp-aspect-ratio" id="ecp-player-container">

          <!-- Thumbnail (la llena JS) -->
          <img id="ecp-main-thumb" alt="" loading="lazy" decoding="async">

          <!-- Botón play (JS lo usa para “activar” iframe) -->
          <button id="ecp-main-play" class="ecp-play-overlay-btn" type="button" aria-label="Reproducir video">
            <div class="ecp-icon-play"></div>
          </button>

          <!-- IFRAME: lo inserta el editor en HTML (NO por JS) -->
          <iframe id="ecp-iframe" title="Video" src="./video_main_files/saved_resource.html" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" allowfullscreen="" loading="lazy" referrerpolicy="strict-origin-when-cross-origin" style="display:none; width:100%; height:100%; border:0;"></iframe>
        </div>

        <h3 class="ecp-main-title" id="ecp-main-title">Cargando...</h3>
        <p class="ecp-main-desc" id="ecp-main-desc"></p>
      </div>
    </div>

    <!-- Derecha -->
    <div class="col-md-4 bannersH">
      <div class="card" style="padding: 15px; border: none; box-shadow: none;">
        <div class="tittle-wrapperH IndicadoresEn ecp-desktop-only">
          <h3 class="title-w">Energía Viva</h3>
        </div>

        <button id="ecp-next-btn" class="ecp-next-card" type="button" aria-label="Reproducir siguiente video">
          <div class="ecp-next-thumb-wrapper">
            <img id="ecp-next-thumb" alt="Siguiente video" loading="lazy" decoding="async">
            <div class="ecp-mini-play"></div>
            <span class="ecp-duration-badge" id="ecp-next-duration" style="display:none;">0:00</span>
          </div>
          <div class="ecp-next-content">
            <span class="ecp-next-label">SIGUIENTE</span>
            <h4 class="ecp-next-title" id="ecp-next-title">Cargando...</h4>
          </div>
        </button>

        <a href="https://www.ecopetrol.com.co/wps/portal/Home/es/NuestraEmpresa/salaPrensa/energia-viva" class="ecp-btn-more">Ver todos los capítulos</a>
      </div>
    </div>

  </div>
