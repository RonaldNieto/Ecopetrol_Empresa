              <style>
        /* Contenedor aspecto 16:9 fijo */
        .ecp-aspect-ratio {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            /* 16:9 */
            background-color: #000;
            display: block;
        }

        .ecp-aspect-ratio img,
        .ecp-aspect-ratio iframe {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            border: none;
        }

        /* Botón Play Superpuesto (Principal) */
        .ecp-play-overlay-btn {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 70px;
            height: 70px;
            background: rgba(255, 255, 255, 0.9);
            border: none;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10;
            transition: transform 0.2s, background 0.2s;
        }

        .ecp-play-overlay-btn:hover {
            transform: translate(-50%, -50%) scale(1.1);
            background: #fff;
        }

        .ecp-icon-play {
            width: 0;
            height: 0;
            border-top: 12px solid transparent;
            border-bottom: 12px solid transparent;
            border-left: 20px solid #003a5d;
            /* Azul corporativo */
            margin-left: 4px;
        }

        /* Info del video principal */
        .ecp-main-title {
            font-size: 1.35rem;
            font-weight: 700;
            margin: 15px;
            line-height: 1.3;
            color: #333;
          border-bottom: none !important;
        }

        .ecp-main-desc {
            font-size: 0.95rem;
            color: #666;
            margin: 0 15px 15px;
            line-height: 1.5;
        }

        /* Bloque "Siguiente Video" */
        .ecp-next-card {
            display: block;
            width: 100%;
            background: none;
            border: 1px solid #e0e0e0;
            border-radius: 4px;
            padding: 0;
            margin-bottom: 15px;
            cursor: pointer;
            text-align: left;
            transition: box-shadow 0.2s;
            overflow: hidden;
        }

        .ecp-next-card:hover {
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
        }

        .ecp-next-thumb-wrapper {
            position: relative;
            width: 100%;
            padding-bottom: 56.25%;
            /* 16:9 thumbnail */
            background: #ddd;
        }

        .ecp-next-thumb-wrapper img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* Icono Play pequeño sobre siguiente */
        .ecp-mini-play {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 36px;
            height: 36px;
            background: rgba(0, 0, 0, 0.6);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .ecp-mini-play::after {
            content: '';
            width: 0;
            height: 0;
            border-top: 6px solid transparent;
            border-bottom: 6px solid transparent;
            border-left: 12px solid #fff;
            margin-left: 4px;
        }

        .ecp-duration-badge {
            position: absolute;
            bottom: 5px;
            right: 5px;
            background: rgba(0, 0, 0, 0.8);
            color: #fff;
            font-size: 0.75rem;
            padding: 2px 6px;
            border-radius: 2px;
        }

        .ecp-next-content {
            padding: 12px;
            background: #fff;
        }

        .ecp-next-label {
            display: block;
            font-size: 0.7rem;
            color: #777;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            font-weight: 700;
            margin-bottom: 4px;
        }

        .ecp-next-title {
            font-size: 0.95rem;
            margin: 0;
            color: #111;
            font-weight: 600;
            line-height: 1.35;
        }

        /* Botón estilo "Ver más" */
        .ecp-btn-more {
            display: block;
            width: 100%;
            text-align: center;
            background-color: #CCD32A;
            /* Verde-limón base */
            color: #00214D;
            font-weight: 700;
            text-decoration: none;
            padding: 10px 0;
            border-radius: 4px;
            text-transform: uppercase;
            font-size: 0.9rem;
            transition: background-color 0.2s;
        }

        

        /* === AJUSTES RESPONSIVE === */
        /* Estilos base (Mobile First) */
        .ecp-mobile-title {
            display: block;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 1px solid #ddd;
        }

        .ecp-mobile-title h3 {
            font-size: 24px;
            margin: 0;
            color: #00214D;
            font-weight: bold;
            border-left: 4px solid #dbe424;
            padding-left: 10px;
        }

        /* Ocultar elementos de escritorio en móvil */
        .ecp-desktop-only {
            display: none !important;
        }

        /* Ocultar el segundo video en móvil */
        #ecp-next-btn {
            display: none;
        }

        /* Media Query para Tablet/Desktop (min-width: 768px) */
        @media (min-width: 768px) {
            .ecp-mobile-title {
                display: none !important;
            }

            .ecp-desktop-only {
                display: block !important;
            }

            #ecp-next-btn {
                display: block;
                /* Volver a mostrar en desktop */
            }
        }

.col-md-4.bannersH {
    float: left;
    padding-right: 0;
    padding-left: 0;}

.col-md-8.bannersH {
